# Kaggle credentials (option A: legacy key)
KAGGLE_USERNAME=your_username
KAGGLE_KEY=your_api_key

# Kaggle credentials (option B: point to kaggle.json dir)
# KAGGLE_CONFIG_DIR=/home/user/.kaggle

# Postgres
DATABASE_URL=postgresql+asyncpg://harness:harness@localhost:5432/harness

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5000

# Gateway
PORT=8743
DEBUG=false
WORKER_TOKEN=change-me-in-production
